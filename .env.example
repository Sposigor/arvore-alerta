# Copernicus CDSE — Sentinel-2 via openEO
# Crie conta gratuita em: https://dataspace.copernicus.eu
CDSE_USER=seu@email.com
CDSE_PASS=sua_senha

# NASA FIRMS — focos de queimada (VIIRS/MODIS)
# Gere a chave em: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# SQLite — opcional; em produção aponte para volume persistente (ex.: /data/arvore_alerta.db)
DB_PATH=arvore_alerta.db
